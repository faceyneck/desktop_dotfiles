# ~/.config/sway/config.d/media.conf
# Media Keybindings powered by playerctl and Dunst popups

bindsym XF86AudioPlay exec ~/.config/sway/scripts/sway-media-helper play-pause
bindsym XF86AudioPause exec ~/.config/sway/scripts/sway-media-helper play-pause
bindsym XF86AudioNext exec ~/.config/sway/scripts/sway-media-helper next
bindsym XF86AudioPrev exec ~/.config/sway/scripts/sway-media-helper previous

