exec_always {
    gsettings set org.gnome.desktop.interface cursor-theme 'Breeze_Light'
    gsettings set org.gnome.desktop.interface cursor-size 32
}




### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l
# Your preferred terminal emulator
# Recommends: foot
set $term wezterm 

# Your preferred application launcher
 set $menu rofi -show drun -show-icons

 # Add this near the TOP of your ~/.config/sway/config file
 exec_always {
     export GTK_THEME="Adwaita:dark"
 }


 # Setting up rofi to work as an alt+tab feature:
 bindsym $mod+Tab exec rofi -show window -show-icons

 # Rofi emoji selector
 bindsym $mod+Period exec rofimoji


### Output configuration
#
# Default wallpaper (more resolutions are available in /usr/share/backgrounds/sway/)
# Requires: desktop-backgrounds-compat, swaybg, jxl-pixbuf-loader
output * bg /home/faceyneck/git/plasma-workspace-wallpapers/Path/contents/images/1920x1080.jpg  fill
#
# Example configuration:
#
#   output HDMI-A-1 resolution 1920x1080 position 1920,0
#
# You can get the names of your outputs by running: swaymsg -t get_outputs

### Idle configuration
#
# Example configuration:
#
 exec swayidle -w \
          timeout 1200 'swaylock -f -c 000000' \
          timeout 1800 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
          before-sleep 'swaylock -f -c 000000'
#
# This will lock your screen after 300 seconds of inactivity, then turn off
# your displays after another 300 seconds, and turn your screens back on when
# resumed. It will also lock your screen before your computer goes to sleep.

# Adding swaylock bind:
bindsym $mod+Ctrl+l exec swaylock -i /home/faceyneck/git/plasma-workspace-wallpapers/Path/contents/images/1920x1080.jpg

# Adding tap-to-click for mouse pad:
input "type:touchpad" {
    tap enabled
    tap_button_map lrm
}

### Input configuration
#
# Example configuration:
#
#   input "2:14:SynPS/2_Synaptics_TouchPad" {
#       dwt enabled
#       tap enabled
#       natural_scroll enabled
#       middle_emulation enabled
#   }
#
# You can get the names of your inputs by running: swaymsg -t get_inputs
