# Launching waybar with ~/.local/bin/waybar-safe.sh
exec ~/.local/bin/waybar-safe


# Script to restart Waybar
bindsym $mod+Shift+r exec ~/.config/waybar/scripts/launch.sh

# Launch gammasteppy.sh script
